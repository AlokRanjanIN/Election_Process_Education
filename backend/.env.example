# Backend environment variables
# Copy this file to your shell environment or deployment configuration.
# The backend does not automatically load .env files.

ENVIRONMENT=development
GCP_PROJECT_ID=YOUR_GCP_PROJECT_ID
GCP_LOCATION=asia-south1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

VERTEX_LLM_MODEL=gemini-1.5-flash-001
VERTEX_EMBEDDING_MODEL=text-embedding-004
VERTEX_LLM_TEMPERATURE=0.0

RAG_TOP_K=5
RAG_MAX_QUERY_LENGTH=300

RATE_LIMIT_FAQ=10/minute
RATE_LIMIT_TIMELINE=30/minute
RATE_LIMIT_DEFAULT=60/minute
